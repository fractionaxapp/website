NEXT_PUBLIC_GA_ID=your-ga-measurement-id

# Neon Postgres connection string (use the pooled connection URL from Neon dashboard)
DATABASE_URL=postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require

# Admin dashboard auth — pick a long, random password and a separate 32+ char secret
ADMIN_PASSWORD=change-me
ADMIN_SECRET=change-me-to-a-long-random-string-of-at-least-32-chars
